# Python / Jupyter のキャッシュ・チェックポイント
__pycache__/
*.pyc
.ipynb_checkpoints/

# スキル直下に置く venv（環境固有・同期しない）
.venv/

# 入力置き場（手順書・設計値・現行config。機密を含みうるためローカルのみ）
# フォルダ自体は .gitkeep で残し、中身は追跡しない
inbox/*
!inbox/.gitkeep

# 実行ごとのアーカイブ（runs/<日時>_<名前>/ ・中間JSON・生成HTML）。ローカルのみ
runs/

# 旧: レビュー作業ディレクトリ（後方互換で残置）
review-work/
