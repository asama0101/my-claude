{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read(./**)",
      "Write(./**)",
      "Edit(./**)",
      "Bash(*)"
    ],
    "deny": [
      "Read(**/.env)",
      "Write(**/.env)",
      "Edit(**/.env)",
      "Read(**/*.key)",
      "Write(**/*.key)",
      "Edit(**/*.key)",
      "Read(**/*.pem)",
      "Write(**/*.pem)",
      "Edit(**/*.pem)",
      "Read(**/id_rsa)",
      "Write(**/id_rsa)",
      "Edit(**/id_rsa)",
      "Read(**/authorized_keys)",
      "Write(**/authorized_keys)",
      "Edit(**/authorized_keys)",
      "Bash(sudo *)",
      "Edit(/etc/**)",
      "Edit(/usr/**)",
      "Edit(/var/**)",
      "Edit(/bin/**)",
      "Edit(/sbin/**)",
      "Edit(/boot/**)",
      "Edit(/root/**)",
      "Edit(/lib/**)",
      "Edit(/lib64/**)",
      "Edit(/proc/**)",
      "Edit(/sys/**)",
      "Write(/etc/**)",
      "Write(/usr/**)",
      "Write(/var/**)",
      "Write(/bin/**)",
      "Write(/sbin/**)",
      "Write(/boot/**)",
      "Write(/root/**)",
      "Write(/lib/**)",
      "Write(/lib64/**)",
      "Write(/proc/**)",
      "Write(/sys/**)"
    ],
    "ask": [
      "Bash(git push *)",
      "Bash(git reset --hard*)",
      "Bash(git stash drop*)",
      "Bash(git stash clear*)",
      "Bash(git branch -D*)",
      "WebFetch"
    ],
    "defaultMode": "plan",
    "disableBypassPermissionsMode": "disable"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "__CLAUDE_HOME__/hooks/bash-guard.sh"
          },
          {
            "type": "command",
            "command": "__CLAUDE_HOME__/hooks/venv-guard.sh"
          }
        ]
      },
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "__CLAUDE_HOME__/hooks/context7-plan-remind.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit|NotebookEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "__CLAUDE_HOME__/hooks/workspace-guard.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "__CLAUDE_HOME__/hooks/tdd-guard.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "__CLAUDE_HOME__/hooks/session-close-remind.sh"
          },
          {
            "type": "command",
            "command": "__CLAUDE_HOME__/hooks/session-retrospective.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash __CLAUDE_HOME__/statusline-command.sh"
  },
  "enabledPlugins": {
    "skill-creator@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true
  },
  "effortLevel": "high",
  "remoteControlAtStartup": true,
  "inputNeededNotifEnabled": true,
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true
}
